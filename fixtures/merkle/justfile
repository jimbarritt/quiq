default: test

build:
    ./gradlew build

test:
    ./gradlew test
    quiq --report-junit
    open build/reports/tests/unit/quiq-report.html

acceptance-cuke:
    ./gradlew acceptanceCuke || true
    quiq --report-cuke
    open build/reports/tests/acceptance/cucumber/quiq-report.html

dist:
    ./gradlew shadowJar

run *ARGS:
    ./gradlew run --args="{{ARGS}}"
